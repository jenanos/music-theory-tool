generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth.js models ──────────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  name          String?
  image         String?
  role          String    @default("member") // "admin" | "member"
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts         Account[]
  sessions         Session[]
  songs            Song[]
  groupMemberships GroupMember[]

  @@map("users")
}

model Account {
  id                String  @id @default(uuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Groups ──────────────────────────────────────────────────────

model Group {
  id           String   @id @default(uuid())
  name         String
  enabledPages String[] @default(["charts", "progressions"]) @map("enabled_pages")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  members GroupMember[]
  songs   Song[]

  @@map("groups")
}

model GroupMember {
  id      String @id @default(uuid())
  userId  String @map("user_id")
  groupId String @map("group_id")
  role    String @default("member") // "admin" | "member"

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@map("group_members")
}

// ─── Songs ──────────────────────────────────────────────────────

model Song {
  id          String   @id
  title       String
  artist      String?
  key         String?
  notes       String?
  arrangement String[] @default([])
  visibility  String   @default("private") // "private" | "group" | "shared"
  userId      String?  @map("user_id")
  groupId     String?  @map("group_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  sections    Section[]

  user  User?  @relation(fields: [userId], references: [id])
  group Group? @relation(fields: [groupId], references: [id])

  @@map("songs")
}

model Section {
  id          String   @id
  songId      String   @map("song_id")
  label       String
  description String?
  chordLines  String[] @default([]) @map("chord_lines")
  degreeLines String[] @default([]) @map("degree_lines")
  notes       String?
  orderIndex  Int      @map("order_index")
  song        Song     @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@index([songId, orderIndex])
  @@map("sections")
}

model OriginalSong {
  id          String            @id
  title       String
  artist      String?
  key         String?
  notes       String?
  arrangement String[]          @default([])
  createdAt   DateTime          @default(now()) @map("created_at")
  sections    OriginalSection[]

  @@map("original_songs")
}

model OriginalSection {
  id          String       @id
  songId      String       @map("song_id")
  label       String
  description String?
  chordLines  String[]     @default([]) @map("chord_lines")
  degreeLines String[]     @default([]) @map("degree_lines")
  notes       String?
  orderIndex  Int          @map("order_index")
  song        OriginalSong @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@index([songId, orderIndex])
  @@map("original_sections")
}

model SavedProgression {
  id        String   @id
  name      String
  tonic     String
  mode      String
  sequence  String[] @default([])
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("saved_progressions")
}
