DATABASE_URL=postgresql://postgres:postgres@localhost:5434/music_theory_dev?schema=public

# ── Auth.js (NextAuth v5) ─────────────────────────────────────────
# I dev er det OK å la disse stå med defaults - AUTH_SECRET har en
# dev-fallback i koden og AUTH_URL peker på localhost:3001.
# I prod MÅ AUTH_SECRET settes (openssl rand -base64 32).
AUTH_SECRET=change-me-to-a-random-secret-in-production
AUTH_URL=http://localhost:3001

# ── Admin-bruker ──────────────────────────────────────────────────
# E-posten som er admin i appen. Brukes til flere ting:
#   1. Autoriserer innlogging (kun ADMIN_EMAIL eller inviterte brukere
#      kan logge inn via signIn-callbacken i auth.ts)
#   2. Opprettes automatisk som role="admin" på første login
#   3. Seed-scriptet (pnpm db:seed) oppretter samme bruker og legger
#      den i "Bandet"-gruppa
# Må være en ekte innboks du faktisk kan motta e-post på — Resend
# sender magic link / OTP dit når du logger inn.
ADMIN_EMAIL=din@epost.no

# ── Resend (magic link + OTP via e-post) ──────────────────────────
# Dev-bypassen er fjernet, så Resend trengs også for å logge inn
# lokalt. Hent API-nøkkel fra https://resend.com/api-keys.
#
# Gratis-planen:
#   - Avsender må være onboarding@resend.dev (default nedenfor) eller
#     et verifisert domene i Resend-kontoen din
#   - Mottaker må være e-posten du registrerte Resend-kontoen med
# For å sende fra egen avsender-adresse, verifiser domenet hos Resend.
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=Music Theory Tool <onboarding@resend.dev>
