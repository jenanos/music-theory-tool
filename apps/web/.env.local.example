DATABASE_URL=postgresql://postgres:postgres@localhost:5434/music_theory_dev?schema=public

# Auth.js (NextAuth v5)
AUTH_SECRET=change-me-to-a-random-secret-in-production
AUTH_URL=http://localhost:3001

# Dev: e-postadressen som seedes som admin i dev (bruk en ekte innboks som kan motta magic link/OTP)
DEV_ADMIN_EMAIL=dev@example.com

# Resend (magic link + OTP via e-post) - må settes både i dev og prod
# RESEND_API_KEY=re_your_resend_api_key
# EMAIL_FROM=Music Theory Tool <noreply@yourdomain.com>
