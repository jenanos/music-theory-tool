generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  role      String   @default("member") // "admin" | "member"
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  magicLinks MagicLink[]
  sessions   Session[]

  @@map("users")
}

model MagicLink {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String    @map("user_id")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("magic_links")
}

model Session {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("sessions")
}

model Song {
  id          String    @id
  title       String
  artist      String?
  key         String?
  notes       String?
  arrangement String[]  @default([])
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  sections    Section[]

  @@map("songs")
}

model Section {
  id          String   @id
  songId      String   @map("song_id")
  label       String
  description String?
  chordLines  String[] @default([]) @map("chord_lines")
  degreeLines String[] @default([]) @map("degree_lines")
  notes       String?
  orderIndex  Int      @map("order_index")
  song        Song     @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@index([songId, orderIndex])
  @@map("sections")
}

model OriginalSong {
  id          String            @id
  title       String
  artist      String?
  key         String?
  notes       String?
  arrangement String[]          @default([])
  createdAt   DateTime          @default(now()) @map("created_at")
  sections    OriginalSection[]

  @@map("original_songs")
}

model OriginalSection {
  id          String       @id
  songId      String       @map("song_id")
  label       String
  description String?
  chordLines  String[]     @default([]) @map("chord_lines")
  degreeLines String[]     @default([]) @map("degree_lines")
  notes       String?
  orderIndex  Int          @map("order_index")
  song        OriginalSong @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@index([songId, orderIndex])
  @@map("original_sections")
}

model SavedProgression {
  id        String   @id
  name      String
  tonic     String
  mode      String
  sequence  String[] @default([])
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("saved_progressions")
}
